# JWT session signing (must match between web and auth-service)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# API gateway (local default)
API_GATEWAY_URL="http://localhost:3003"

# Optional: legacy web monolith DB (cutover / Prisma studio only — runtime uses the gateway)
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Optional: Railway CLI / deploy:be
# RAILWAY_TOKEN=""

# --- Local Docker infra (yarn infra:up / yarn dev:complete) ---

