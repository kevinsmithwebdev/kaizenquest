# PostgreSQL connection string for the web monolith (use Neon's pooled URL in production)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# JWT session signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=""

# Resend email (required for sign-up verification in production)
RESEND_API_KEY=""
EMAIL_FROM="Kaizen Quest <onboarding@resend.dev>"

# Optional: Vercel CLI token for non-interactive deploy (https://vercel.com/account/tokens)
# VERCEL_TOKEN=""
# SEED_USER_EMAIL=""
# SEED_RESEED="false"

# --- Local Docker infra (Phase 1+) ---
# Start with: yarn infra:up
# Web app keeps DATABASE_URL above until Phase 3/4 cutover.

AUTH_DATABASE_URL="postgresql://kaizen:kaizen@localhost:5433/auth_db"
GOALS_DATABASE_URL="postgresql://kaizen:kaizen@localhost:5434/goals_db"
ANALYTICS_DATABASE_URL="postgresql://kaizen:kaizen@localhost:5435/analytics_db"
# NOTIFICATIONS_DATABASE_URL="postgresql://kaizen:kaizen@localhost:5436/notifications_db"

KAFKA_BROKERS="localhost:9092"
