# PostgreSQL connection string (use Neon's pooled URL in production)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# JWT session signing (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=""

# Resend email (required for sign-up verification in production)
RESEND_API_KEY=""
EMAIL_FROM="Kaizen Quest <onboarding@resend.dev>"

# Optional: Vercel CLI token for non-interactive deploy (https://vercel.com/account/tokens)
# VERCEL_TOKEN=""
# SEED_USER_EMAIL=""
# SEED_RESEED="false"
