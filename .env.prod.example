# Copy to .env.prod on the VPS (never commit .env.prod).
# cp .env.prod.example .env.prod

# Public IP or domain (used for CORS until web is on the same host)
VPS_PUBLIC_URL=http://159.69.146.228

# Must match between auth-service and web (when web is deployed)
SESSION_SECRET=

# Postgres on the shared platform container (hostname `postgres` on `internal`)
POSTGRES_PASSWORD=
AUTH_DATABASE_URL=postgresql://platform:${POSTGRES_PASSWORD}@postgres:5432/auth_db
GOALS_DATABASE_URL=postgresql://platform:${POSTGRES_PASSWORD}@postgres:5432/goals_db
ANALYTICS_DATABASE_URL=postgresql://platform:${POSTGRES_PASSWORD}@postgres:5432/analytics_db

# Shared Redpanda on the VPS (hostname `redpanda` on `internal`)
KAFKA_BROKERS=redpanda:9092

# api-gateway CORS
WEB_ORIGIN=${VPS_PUBLIC_URL}
