{
  "name": "kaizen",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/shared/utils",
    "libs/shared/contracts",
    "libs/shared/nestjs",
    "libs/shared/api-client",
    "libs/domain/goals",
    "libs/domain/auth"
  ],
  "scripts": {
    "analytics:serve": "nx serve analytics-service",
    "auth:migrate": "nx run auth-service:prisma-migrate",
    "auth:serve": "nx serve auth-service",
    "build": "nx build web",
    "build:services": "nx run-many -t build -p auth-service,goals-service,analytics-service,api-gateway",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "deploy:be": "node scripts/deploy-be.mjs",
    "deploy:be:vps": "bash scripts/deploy-be-vps.sh",
    "dev": "nx dev web",
    "dev:complete": "node scripts/dev-complete.mjs",
    "format": "prettier --write .",
    "gateway:serve": "nx serve api-gateway",
    "goals:serve": "nx serve goals-service",
    "infra:down": "nx run infra:down",
    "infra:logs": "nx run infra:logs",
    "infra:ps": "nx run infra:ps",
    "infra:up": "nx run infra:up",
    "lint": "nx run-many -t lint",
    "migrate:be": "node scripts/migrate-be.mjs",
    "cutover:monolith": "node scripts/cutover-monolith-data.mjs",
    "postinstall": "node scripts/ensure-web-next-links.mjs && prisma generate",
    "predev": "node scripts/ensure-web-next-links.mjs && prisma generate",
    "services:serve": "nx run-many -t serve -p auth-service,goals-service,analytics-service,api-gateway",
    "sonar": "sonar",
    "start": "nx start web",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "vitest run",
    "typecheck": "nx run-many -t typecheck",
    "validate": "node scripts/validate.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/microservices": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "kafkajs": "^2.2.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nx/eslint": "^23.1.0",
    "@nx/js": "^23.1.0",
    "@nx/nest": "^23.1.0",
    "@nx/next": "^23.1.0",
    "@nx/vite": "^23.1.0",
    "@nx/workspace": "^23.1.0",
    "@sonar/scan": "^4.3.8",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "nx": "^23.1.0",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
