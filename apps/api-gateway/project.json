{
  "name": "api-gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api-gateway/src",
  "projectType": "application",
  "tags": ["scope:gateway", "type:app"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch --tsconfig apps/api-gateway/tsconfig.app.json apps/api-gateway/src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/build-service.mjs api-gateway"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/apps/api-gateway/main.mjs"
      },
      "dependsOn": ["build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/api-gateway/tsconfig.app.json"
      }
    }
  }
}
