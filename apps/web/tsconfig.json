{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@kaizen/shared-utils": ["../../libs/shared/utils/src/index.ts"],
      "@kaizen/shared-contracts": ["../../libs/shared/contracts/src/index.ts"],
      "@kaizen/shared-api-client": [
        "../../libs/shared/api-client/src/index.ts"
      ],
      "@kaizen/domain-goals": ["../../libs/domain/goals/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
