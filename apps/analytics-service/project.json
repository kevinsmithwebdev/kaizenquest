{
  "name": "analytics-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/analytics-service/src",
  "projectType": "application",
  "tags": ["scope:analytics", "type:app"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch --tsconfig apps/analytics-service/tsconfig.app.json apps/analytics-service/src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/build-service.mjs analytics-service"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/apps/analytics-service/main.mjs"
      },
      "dependsOn": ["build"]
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate --config apps/analytics-service/prisma.config.ts"
      }
    },
    "prisma-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/analytics-service",
        "command": "prisma migrate dev --config prisma.config.ts --name init"
      }
    },
    "prisma-migrate-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate deploy --config apps/analytics-service/prisma.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/analytics-service/tsconfig.app.json"
      }
    }
  }
}
